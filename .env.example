# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2
# Optional: enable Stage 2 visual answer refinement with a vision-capable model
# OLLAMA_VISION_MODEL=llama3.2-vision

# Qdrant (local Docker)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ColQwen model
COLQWEN_MODEL=vidore/colqwen2-v1.0
COLQWEN_DEVICE=mps   # use "cuda" on Linux/Windows GPU, "cpu" as fallback

# Local paths (defaults work out of the box — no need to change)
DATA_DIR=data
PAGES_DIR=data/pages
RAW_DIR=data/raw
KG_DB_PATH=data/db/knowledge_graph.db
OLLAMA_VISION_MODEL=llama3.2-vision
